{
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ng serve (Firefox)",
      "type": "firefox",
      "request": "launch",
      "preLaunchTask": "ng serve",
      "url": "http://localhost:4200/",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "ng test",
      "type": "node-terminal",
      "request": "launch",
      "command": "nix develop . --command sh -c 'cd stadtmeise && npm run test'",
      "cwd": "${workspaceFolder}/.."
    },
  ]
}
