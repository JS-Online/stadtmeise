{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ng serve",
      "type": "shell",
      "command": "nix develop . --command sh -c 'cd stadtmeise && npm run start'",
      "options": {
        "cwd": "${workspaceFolder}/.."
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Building\\.\\.\\."
          },
          "endsPattern": {
            "regexp": "Local:.*http://localhost"
          }
        }
      }
    },
    {
      "label": "ng test",
      "type": "shell",
      "command": "nix develop . --command sh -c 'cd stadtmeise && npm run test'",
      "options": {
        "cwd": "${workspaceFolder}/.."
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Building\\.\\.\\."
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    }
  ]
}
